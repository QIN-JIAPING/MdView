<Window x:Class="MdView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MdView"
        Icon="app_icon.ico"
        Height="720" Width="1400"
        WindowStartupLocation="CenterScreen"
        FontFamily="system-ui, -apple-system, 'Microsoft YaHei', sans-serif"
        FontSize="14">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0FDF4" Offset="0.0"/>
            <GradientStop Color="#F8FAFC" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- 翡翠绿主题色 -->
        <Color x:Key="Emerald500">#10B981</Color>
        <Color x:Key="Emerald50">#ECFDF5</Color>
        <SolidColorBrush x:Key="EmeraldBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="EmeraldLightBrush" Color="#ECFDF5"/>

        <!-- 文字色 -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827"/>
        <SolidColorBrush x:Key="TextBodyBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="IconForegroundBrush" Color="#4B5563"/>

        <!-- 按钮底色 -->
        <SolidColorBrush x:Key="DarkBtnBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="InputBgBrush" Color="#F9FAFB"/>

        <!-- 弥散阴影（翡翠绿调） -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="24" Opacity="0.08"
                          ShadowDepth="4" Color="#10B981"/>

        <!-- 侧边栏阴影 -->
        <DropShadowEffect x:Key="SidebarShadow" BlurRadius="16" Opacity="0.06"
                          ShadowDepth="2" Color="#10B981"/>

        <!-- 按钮样式 — 深炭黑圆角矩形 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DarkBtnBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 图标按钮样式 — 圆形浅灰背景 -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource LightGrayBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource IconForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="18" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 侧边栏列表项样式 -->
        <Style x:Key="SidebarItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,2,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBodyBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource EmeraldLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D1FAE5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主布局 -->
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 侧边栏（卡片） ===== -->
        <Border Grid.Column="0" Width="200"
                Background="White" CornerRadius="16"
                Effect="{StaticResource SidebarShadow}">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="16,18,16,12">
                    <TextBlock Text="MdView" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>

                <!-- 底栏 -->
                <Border DockPanel.Dock="Bottom" Background="#F9FAFB" CornerRadius="0,0,16,16"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock x:Name="StatusText" Text="就绪" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <CheckBox x:Name="AutoRefreshCheck" Content="实时刷新" IsChecked="True"
                                  FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                  Margin="0,4,0,0"/>
                        <TextBlock Text="F5 刷新 · Ctrl+O 打开" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 最近文件标题 -->
                <Grid DockPanel.Dock="Bottom" Margin="14,8,14,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="最近文件" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBodyBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="ClearHistoryBtn" Content="✕" FontSize="9"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Cursor="Hand" Padding="4,0" Click="OnClearHistory"
                            ToolTip="清除历史"/>
                </Grid>

                <!-- 文件列表 -->
                <ListBox x:Name="RecentFilesList" Background="White" BorderThickness="0"
                         FontSize="12" Foreground="{StaticResource TextBodyBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         PreviewMouseLeftButtonUp="OnRecentFileClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarItem}"/>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ===== 主内容 ===== -->
        <Grid x:Name="ContentGrid" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左面板（卡片） -->
            <Grid Grid.Column="0" Effect="{StaticResource CardShadow}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border x:Name="TitleBarL" Grid.Row="0" Background="White" CornerRadius="16,16,0,0"
                        Padding="14,8" MouseDown="OnPanelFocusL">
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="TitleTextL" Text="未选择"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PathTextL" Margin="8,0,0,0"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="ToggleSplitBtn" Content="◫" Style="{StaticResource IconBtn}"
                                DockPanel.Dock="Right" ToolTip="切换分栏" Click="OnToggleSplit"
                                Margin="0,0,8,0"/>
                        <Button Content="📂" Style="{StaticResource IconBtn}"
                                DockPanel.Dock="Right" ToolTip="打开文件 (Ctrl+O)" Click="OnOpenL"
                                Margin="0,0,0,0"/>
                    </DockPanel>
                </Border>
                <Border Grid.Row="1" Background="White" CornerRadius="0,0,16,16" Padding="0,0,0,2">
                    <wv2:WebView2 x:Name="WebViewL" DefaultBackgroundColor="#FFFFFF"/>
                </Border>
            </Grid>

            <!-- 分隔条 -->
            <GridSplitter x:Name="SplitterControl" Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch" Background="Transparent"
                          ResizeBehavior="PreviousAndNext" ShowsPreview="True" Cursor="SizeWE"/>

            <!-- 右面板（卡片） -->
            <Grid x:Name="RightPanel" Grid.Column="2" Effect="{StaticResource CardShadow}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border x:Name="TitleBarR" Grid.Row="0" Background="White" CornerRadius="16,16,0,0"
                        Padding="14,8" MouseDown="OnPanelFocusR">
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="TitleTextR" Text="未选择"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PathTextR" Margin="8,0,0,0"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Content="📂" Style="{StaticResource IconBtn}"
                                DockPanel.Dock="Right" ToolTip="打开文件" Click="OnOpenR"
                                Margin="0,0,4,0"/>
                    </DockPanel>
                </Border>
                <Border Grid.Row="1" Background="White" CornerRadius="0,0,16,16" Padding="0,0,0,2">
                    <wv2:WebView2 x:Name="WebViewR" DefaultBackgroundColor="#FFFFFF"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>